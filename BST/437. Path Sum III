# Definition for a binary tree node.
# class TreeNode:
#     def __init__(self, val=0, left=None, right=None):
#         self.val = val
#         self.left = left
#         self.right = right
class Solution:
    def pathSum(self, root, ts):
        if not root:
            return 0

        def dfs(node, sumval):
            if not node:
                return 0

            sumval += node.val
            if sumval == ts:
                count = 1
            else:
                count = 0

            count += dfs(node.left, sumval)
            count += dfs(node.right, sumval)
            return count
        return (dfs(root, 0) + self.pathSum(root.left, ts) + self.pathSum(root.right, ts))
